@model Commercial_DataRepo.Repo_Models.Product

@{
    ViewData["Title"] = "Add Product";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>@ViewData["Title"]</h1>
            <hr />

            @if (!string.IsNullOrEmpty(ViewBag.Message))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @ViewBag.Message
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form asp-action="AddDetail" asp-controller="Commercial" method="post">
                <div class="form-group mb-3">
                    <label asp-for="PName" class="form-label">Product Name</label>
                    <input asp-for="PName" class="form-control" placeholder="Enter product name" />
                    <span asp-validation-for="PName" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="SQty" class="form-label">Stock Quantity</label>
                    <input asp-for="SQty" class="form-control" type="number" placeholder="Enter quantity" />
                    <span asp-validation-for="SQty" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary">Add Product</button>
                    <a asp-action="Details" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
