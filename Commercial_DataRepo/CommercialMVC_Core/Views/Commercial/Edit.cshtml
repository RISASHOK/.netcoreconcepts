@model Commercial_DataRepo.Repo_Models.SalesDetail

@{
    ViewData["Title"] = "Edit Sales Detail";
}

<h1>Sale The Product</h1>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="PId" class="control-label">Product ID</label>
                <input asp-for="PId" class="form-control" />
                <span asp-validation-for="PId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="SaQty" class="control-label">Sales Quantity</label>
                <input asp-for="SaQty" class="form-control" />
                <span asp-validation-for="SaQty" class="text-danger"></span>
            </div>

          @*   <div class="form-group">
                <label asp-for="SaDate" class="control-label">Sales Date</label>
                <input asp-for="SaDate" type="datetime-local" class="form-control" />
                <span asp-validation-for="SaDate" class="text-danger"></span>
            </div> *@

            <div class="form-group">
                <input type="submit" asp-action="Edit" value="Sale Product" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Details" class="btn btn-secondary">Back to List</a>
</div>

@if (!string.IsNullOrEmpty(ViewBag.Message))
{
    <script>
        alert("@Html.Raw(ViewBag.Message)");
        window.location.href = "@Url.Action("Details")";
    </script>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
