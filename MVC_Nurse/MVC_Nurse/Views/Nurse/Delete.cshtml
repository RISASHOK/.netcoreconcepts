@model Nurse_data.Models.Nurse

@{
    ViewData["Title"] = "Delete Nurse";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>Delete Nurse Record</h1>
            <hr />

            <div class="alert alert-danger" role="alert">
                <strong>Warning!</strong> This action cannot be undone. Are you sure you want to delete this nurse record?
            </div>

            <div class="card">
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <strong>ID:</strong>
                        </div>
                        <div class="col-md-8">
                            @Html.DisplayFor(model => model.HId)
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <strong>Name:</strong>
                        </div>
                        <div class="col-md-8">
                            @Html.DisplayFor(model => model.Name)
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <strong>Department:</strong>
                        </div>
                        <div class="col-md-8">
                            @Html.DisplayFor(model => model.Dept)
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <strong>Gender:</strong>
                        </div>
                        <div class="col-md-8">
                            @Html.DisplayFor(model => model.Gender)
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <form asp-action="Delete" class="d-inline">
                    <input type="hidden" asp-for="HId" />
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </form>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </div>
    </div>
</div>
